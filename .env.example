# ============================================================
# LocalVoice2Action — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this .env.example is committed.
# ============================================================

# ----- Gemini (SERVER-ONLY) ----------------------------------
# NO NEXT_PUBLIC_ prefix: this key must never reach the browser.
# It is read only inside server-side route handlers (lib/agents/*).
GEMINI_API_KEY=
# Model id used by all five agents (multimodal, GA, tuned for tool-calling).
GEMINI_MODEL=gemini-3.5-flash

# ----- Google Maps (CLIENT) ----------------------------------
# Must be NEXT_PUBLIC_ — the Maps JS API runs in the browser.
# Restrict this key by HTTP referrer in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ----- Firebase client SDK (CLIENT — safe to expose) ---------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ----- Firebase Admin SDK (SERVER-ONLY) ----------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the private key as a single line with literal \n escapes.
# admin.ts replaces \n with real newlines at runtime.
FIREBASE_ADMIN_PRIVATE_KEY=
